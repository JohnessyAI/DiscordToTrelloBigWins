# Discord Configuration
# Get your bot token from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Get channel ID by enabling Developer Mode in Discord, then right-click channel > Copy ID
DISCORD_CHANNEL_ID=your_channel_id_here

# Trello Configuration
# Get API key from: https://trello.com/power-ups/admin
TRELLO_API_KEY=your_trello_api_key_here

# Get token by clicking "Token" link on the same page, or visit:
# https://trello.com/1/authorize?expiration=never&name=BigWinsBot&scope=read,write&response_type=token&key=YOUR_API_KEY
TRELLO_TOKEN=your_trello_token_here

# Get list ID by adding .json to your board URL and finding the list in the JSON
# Or use: curl "https://api.trello.com/1/boards/YOUR_BOARD_ID/lists?key=YOUR_KEY&token=YOUR_TOKEN"
TRELLO_LIST_ID=your_trello_list_id_here

# Bot Settings
# Start date for processing historical messages (ISO 8601 format)
START_DATE=2026-01-21T00:00:00.000Z
